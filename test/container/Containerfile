# XDock test container — GNOME Shell headless for CI testing.
# Uses systemd as PID 1 (required for logind which gnome-shell needs).
# gnome-shell runs via dbus-run-session, not a full GNOME session.
#
# Build: podman build --build-arg=fedora_version=44 -t xdock-test:f44 test/container/
# Run:   podman run --rm --cap-add=SYS_ADMIN -td xdock-test:f44
# Test:  podman exec -u gnomeshell $POD start-gnome-headless.sh

ARG fedora_version=44
FROM registry.fedoraproject.org/fedora-minimal:${fedora_version}

RUN microdnf install -y --nodocs \
        gnome-shell gnome-extensions-app \
        dbus-daemon systemd procps-ng unzip \
        mesa-dri-drivers \
        ImageMagick bc && \
    microdnf clean all && \
    rm -rf /var/cache/* /tmp/* /var/tmp/* && \
    systemctl set-default multi-user.target && \
    mkdir -p /etc/systemd/system/systemd-logind.service.d && \
    printf '[Service]\nProtectHostname=no\nPrivateDevices=no\nProtectClock=no\nProtectKernelTunables=no\nProtectKernelModules=no\nProtectKernelLogs=no\nRestrictNamespaces=no\nProtectControlGroups=no\n' \
      > /etc/systemd/system/systemd-logind.service.d/container.conf && \
    adduser -m gnomeshell && \
    mkdir -p /var/lib/systemd/linger && \
    touch /var/lib/systemd/linger/gnomeshell

COPY bin/start-gnome-headless.sh bin/take-screenshot.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/start-gnome-headless.sh /usr/local/bin/take-screenshot.sh

CMD ["/usr/sbin/init"]
