#: Settings.ui:642
msgid ""
"Hide the dock when it obstructs a window of the current application. More "
"refined settings are available."
msgstr ""
"Ezkutatu atrakea uneko aplikazioaren leiho bat eragozten duenean. Ezarpen "
"zehatzagoak erabilgarri daude."

#: Settings.ui:659
msgid "Intelligent autohide"
msgstr "Ezkutatze adimentsua"

#: Settings.ui:735
msgid "Dock size limit"
msgstr "Atrakearen tamaina-muga"

#: Settings.ui:757
msgid "Panel mode: extend to the screen edge"
msgstr "Panel modua: hedatu pantailaren ertzetara"

#: Settings.ui:769
msgid "Place icons to the center"
msgstr "Lerrokatu ikonoak erdian"

#: Settings.ui:794
msgid "Icon size limit"
msgstr "Ikonoen tamaina-muga"

#: Settings.ui:820
msgid "Fixed icon size: scroll to reveal other icons"
msgstr "Ikono-tamaina finkoa: korritu beste ikonoak erakusteko"

#: Settings.ui:848
msgid "Preview size scale"
msgstr "Aurrebistaren eskala"

#: Settings.ui:890
msgid "Position and size"
msgstr "Posizioa eta tamaina"

#: Settings.ui:940
msgid "Show pinned applications"
msgstr "Erakutsi ainguratutako aplikazioak"

#: Settings.ui:977
msgid "Show running applications"
msgstr "Erakutsi martxan dauden aplikazioak"

#: Settings.ui:987
msgid "Isolate workspaces"
msgstr "Isolatu laneako areak"

#: Settings.ui:1000
msgid "Show urgent windows despite current workspace"
msgstr "Erakutsi beste laneko areetako presazko leihoak ere"

#: Settings.ui:1013
msgid "Isolate monitors"
msgstr "Isolatu monitoreak"

#: Settings.ui:1027
msgid "Show open windows' previews"
msgstr "Erakutsi irekitako leihoen aurrebistak"

#: Settings.ui:1064
msgid "Keep the focused application always visible in the dash"
msgstr "Mantendu fokudun aplikazioa beti bistan abiarazle-panelean"

#: Settings.ui:1101
msgid ""
"If disabled, these settings are accessible from gnome-tweak-tool or the "
"extension website."
msgstr ""
"Desgaituz gero, ezarpen hauek gnome-tweak-tool aplikazioan edo hedapenen "
"webgunean daude erabilgarri."

#: Settings.ui:1118
msgid "Show <i>Applications</i> icon"
msgstr "Erakutsi <i>Aplikazioak</i> ikonoa"

#: Settings.ui:1129
msgid "Move at beginning of the dock"
msgstr "Eraman atrakearen hasierara"

#: Settings.ui:1150
msgid "Animate <i>Show Applications</i>"
msgstr "Animatu <i>Erakutsi aplikazioak</i> ekintza"

#: Settings.ui:1171
msgid "Put <i>Show Applications</i> in a dock edge when using Panel mode"
msgstr ""
"Panel modua erabiltzean, jarri <i>Erakutsi aplikazioak</i> botoia atrakearen "
"ertz batean"

#: Settings.ui:1211
msgid "Show trash can"
msgstr "Erakutsi zakarrontzia"

#: Settings.ui:1248
msgid "Show volumes and devices"
msgstr "Erakutsi bolumenak eta gailuak"

#: Settings.ui:1258
msgid "Only if mounted"
msgstr "Muntatuta badaude soilik"

#: Settings.ui:1271
msgid "Include network volumes"
msgstr "Erakutsi sareko bolumenak"

#: Settings.ui:1311
msgid "Isolate volumes, devices and trash windows from file manager"
msgstr ""
"Bereizi bolumen, gailu eta zakarrontziaren leihoak eta fitxategi-kudeatzailea"

#: Settings.ui:1348
msgid "Wiggle urgent applications"
msgstr "Dardara egin presazko aplikazioetan"

#: Settings.ui:1385
msgid "Hide application tooltip"
msgstr "Ezkutatu aplikazioen argibideak"

#: Settings.ui:1422
msgid "Show icons emblems"
msgstr "Erakutsi enblemak ikonoetan"

#: Settings.ui:1435
msgid ""
"When enabled application icons will show notification counters and progress-"
"bars (if Unity API is used)."
msgstr ""
"Gaituta badago, aplikazioen ikonoetan jakinarazpen kontagailuak eta "
"aurrerapen-barrak erakutsiko dira (Unity APIa erabiltzen bada)."

#: Settings.ui:1450
msgid "Show the number of unread notifications"
msgstr "Erakutsi irakurri gabeko jakinarazpenen kopurua"

#: Settings.ui:1471
msgid "Application-provided counter overrides the notifications counter"
msgstr ""
"Aplikazioak eskainitako kontagailuak jakinarazpenen kontagailuari "
"gainjartzen zaizkio"

#: Settings.ui:1498
msgid "Launchers"
msgstr "Abiarazleak"

#: Settings.ui:1538
msgid ""
"Enable Super+(0-9) as shortcuts to activate apps. It can also be used "
"together with Shift and Ctrl."
msgstr ""
"Gaitu Super+(0-9) aplikazioak aktibatzeko laster-tekla gisa. Maius eta Ktrl "
"teklekin batera ere erabil daiteke."

#: Settings.ui:1557
msgid "Use keyboard shortcuts to activate apps"
msgstr "Erabili laster-teklak aplikazioak aktibatzeko"

#: Settings.ui:1633
msgid "Behaviour when clicking on the icon of a running application."
msgstr "Martxan dagoen aplikazio baten ikonoak klik egitean duen portaera."

#: Settings.ui:1651
msgid "Click action"
msgstr "Klik ekintza"

#: Settings.ui:1685
msgid "Minimize"
msgstr "Minimizatu"

#: Settings.ui:1739
msgid "Behaviour when scrolling on the icon of an application."
msgstr "Aplikazio baten ikonoaren gainean sagua korritzean duen portaera."

#: Settings.ui:1757
msgid "Scroll action"
msgstr "Korritze-ekintza"

#: Settings.ui:1774
msgid "Do nothing"
msgstr "Ez egin ezer"

#: Settings.ui:1776
msgid "Switch workspace"
msgstr "Aldatu laneko areaz"

#: Settings.ui:1804
msgid "Behavior"
msgstr "Portaera"

#: Settings.ui:1854
msgid "Save space reducing padding and border radius."
msgstr "Hartu leku gutxiago betegarria eta ertzen erradioa txikituz."

#: Settings.ui:1870
msgid "Shrink the dash"
msgstr "Txikiagotu abiarazle-panela"

#: Settings.ui:1900
msgid "Force straight corner"
msgstr "Behartu erpin zuzena"

#: Settings.ui:1930
msgid "Show overview on startup"
msgstr "Erakutsi ikuspegi orokorra abioan"

#: Settings.ui:1972
msgid ""
"Few customizations meant to integrate the dock with the default GNOME theme. "
"Alternatively, specific options can be enabled below."
msgstr ""
"Atrakea GNOMEren gai lehenetsiarekin integratzeko ezarritako pertsonalizazio "
"txikiak. Honen ordez aukera zehatzak gaitu daitezke jarraian."

#: Settings.ui:1990
msgid "Use built-in theme"
