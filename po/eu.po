#: Settings.ui:41
msgid ""
"When set to minimize, double clicking minimizes all the windows of the "
"application."
msgstr ""
"Minimizatzea hautatuz gero, klik bikoitzak aplikazioaren leiho guztiak "
"minimizatzen ditu."

