# XDock test container — runs GNOME Shell headless for CI testing.
# Wayland only (GNOME 49+, Fedora 43+).
#
# Build: podman build --build-arg=fedora_version=44 -t xdock-test:f44 test/container/
# Run:   podman run --rm --cap-add=SYS_NICE --cap-add=IPC_LOCK -td xdock-test:f44

ARG fedora_version=44
FROM registry.fedoraproject.org/fedora:${fedora_version}

# Core packages for headless Wayland GNOME Shell
RUN dnf update -y && \
    dnf --nodocs install -y \
        gnome-shell gnome-session gnome-extensions-app \
        dbus dbus-tools sudo \
        mesa-dri-drivers ImageMagick bc && \
    dnf --nodocs install -y gnome-session-wayland-session 2>/dev/null || true && \
    dnf --nodocs install -y gnome-terminal 2>/dev/null || true && \
    dnf clean all -y && \
    rm -rf /var/cache/dnf

COPY etc /etc
COPY bin /usr/local/bin

RUN systemctl unmask systemd-logind.service console-getty.service getty.target && \
    systemctl set-default multi-user.target && \
    adduser -m -U -G users,adm gnomeshell && \
    echo "gnomeshell     ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

CMD [ "/usr/sbin/init", "systemd.unified_cgroup_hierarchy=0" ]
